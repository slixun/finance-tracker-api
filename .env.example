# Copy this file to .env and fill in real values. Never commit the actual .env file.

# PostgreSQL connection string (e.g. a free Neon project: https://neon.tech)
# Use the pooled connection string for the running app, the direct one for migrations if needed.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Secret used to sign JWTs. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
secret_key=replace-with-a-long-random-secret

# Optional — defaults shown below
algorithm=HS256
access_token_expire_minutes=30
